{
  "name": "auraxis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "bun --cwd apps/gateway dev",
    "dev:demo": "bun apps/demo/server.ts",
    "build": "bun --cwd packages/shared build && bun --cwd packages/vue build && bun --cwd apps/gateway build",
    "typecheck": "bun --cwd packages/shared typecheck && bun --cwd packages/vue typecheck && bun --cwd apps/gateway typecheck",
    "db:generate": "bun --cwd apps/gateway db:generate",
    "db:migrate": "bun --cwd apps/gateway db:migrate",
    "db:smoke": "bun --cwd apps/gateway db:smoke",
    "test:gateway": "bun --cwd apps/gateway test"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
